# ──────────────────────────────────────────────────────────────
# Environment variables for the Resurgent India AML/CFT platform
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` (it is gitignored).
# In Render / AWS, set these in the service's Environment settings.
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon, RDS, Supabase, etc.)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Secret used to sign JWT session tokens.
# Use a long, random value (32+ chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Runtime environment: development | production
NODE_ENV=development

# External entity/sanction screening engine (server-side proxy in /api/screening).
# Use an https:// URL so the API key isn't sent in cleartext.
SCREENING_UPSTREAM_URL=https://your-screening-host/api/screen
SCREENING_API_KEY=your-screening-api-key
